  "measurement_patterns": [
    {
      "quantity": "energy",
      "unit": "GeV",
      "regex": "(?P<value>\\d+(?:\\.\\d+)?)\\s*GeV"
    },
    {
      "quantity": "emittance",
      "unit": "rad",
      "regex": "(?P<value>\\d+(?:\\.\\d+)?)\\s*(?P<prefix>pm|nm|um|mm)\\s*(?:[·\\-\\s]*rad)"
    },
    {
      "quantity": "circumference",
      "unit": "m",
      "regex": "(?:circumference[^\\n]{0,30}?|C\\s*[~=]|around\\s+)(?P<value>\\d+(?:\\.\\d+)?)\\s*m"
    },
    {
      "quantity": "magnet_strength_k1",
      "unit": "m^-2",
      "regex": "(?:k1|K1)[^\\n]{0,12}?(?P<value>[+-]?\\d+(?:\\.\\d+)?)\\s*m\\^?-?2"
    },
    {
      "quantity": "magnet_strength_k2",
      "unit": "m^-3",
      "regex": "(?:k2|K2)[^\\n]{0,12}?(?P<value>[+-]?\\d+(?:\\.\\d+)?)\\s*m\\^?-?3"
    },
    {
      "quantity": "dynamic_aperture",
      "unit": "mm",
      "regex": "(?:DA|dynamic aperture)[^\\n]{0,20}?(?P<value>\\d+(?:\\.\\d+)?)\\s*mm"
    },
    {
      "quantity": "bunch_length",
      "unit": "mm",
      "regex": "(?:bunch length|sigma_z)[^\\n]{0,20}?(?P<value>\\d+(?:\\.\\d+)?)\\s*mm"
    },
    {
      "quantity": "energy_spread",
      "unit": "",
      "regex": "(?:energy spread|sigma_E)[^\\n]{0,20}?(?P<value>\\d+(?:\\.\\d+)?(?:e[+-]?\\d+)?)\\s*(?:%|)"
    }
  ]
}