# === LLM Configuration ===
# Works with any OpenAI-compatible API: DeepSeek, OpenAI, Together, OpenRouter, Ollama, vLLM, etc.

LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com

# --- Other provider examples (uncomment one) ---
# OpenAI:
#   LLM_MODEL=gpt-4o
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.openai.com/v1
#
# Ollama (local, free):
#   LLM_MODEL=qwen2.5-coder:32b
#   LLM_API_KEY=ollama
#   LLM_BASE_URL=http://localhost:11434/v1
#
# OpenRouter:
#   LLM_MODEL=meta-llama/llama-3-70b-instruct
#   LLM_API_KEY=sk-or-...
#   LLM_BASE_URL=https://openrouter.ai/api/v1

# === Code Execution ===
# "local" uses the Python in .venv (created by scripts/setup_env.py)
# "docker" runs inside the brilliance container (docker compose up --build)
EXECUTOR=docker

# === Agent Settings ===
MAX_MESSAGES=30

# Maximum time (seconds) for code execution (increase for complex lattices)
CODE_TIMEOUT=600
