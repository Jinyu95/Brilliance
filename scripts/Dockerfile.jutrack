# BRILLIANCE — Docker build for the JuTrack sandbox
#
# Stages:
#   julia-deps  — install Julia and precompile JuTrack from the bundled source
#   app         — install Python deps and the Streamlit app
#
# Build:
#   docker build -f scripts/Dockerfile.jutrack -t brilliance:latest .
#
# The build context must be the project root (the default when using
# docker compose from the project root).

# ── Stage 1: Julia + JuTrack precompile ──────────────────────────────────────
FROM python:3.11-slim AS julia-deps

# System packages needed to build Julia packages with native extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git gcc g++ gfortran make \
    && rm -rf /var/lib/apt/lists/*

# Install Julia 1.10 LTS
ARG JULIA_VERSION=1.10.4
ARG JULIA_ARCH=x86_64
RUN curl -fsSL "https://julialang-s3.julialang.org/bin/linux/x64/1.10/julia-${JULIA_VERSION}-linux-${JULIA_ARCH}.tar.gz" \
    | tar -xz -C /opt && \
    ln -s /opt/julia-${JULIA_VERSION}/bin/julia /usr/local/bin/julia

# Copy the bundled JuTrack.jl source
COPY JuTrack.jl /opt/JuTrack.jl

# Set Julia depot inside the container (will be copied to final stage)
ENV JULIA_DEPOT_PATH=/opt/julia_depot
ENV JULIA_PROJECT=/opt/JuTrack.jl

# Pre-instantiate all Julia package dependencies so they are baked into
# the image layer — no network access required at runtime.
RUN julia -e " \
    import Pkg; \
    Pkg.activate(\"/opt/JuTrack.jl\"); \
    Pkg.instantiate(); \
    println(\"JuTrack dependencies installed\"); \
    " 2>&1

# Warm up: import JuTrack once to trigger native-code precompilation.
# This caches the compiled .ji files in JULIA_DEPOT_PATH/compiled/.
RUN julia --project=/opt/JuTrack.jl -e " \
    @time using JuTrack; \
    println(\"JuTrack precompile complete\"); \
    " 2>&1

# ── Stage 2: Python app ───────────────────────────────────────────────────────
FROM python:3.11-slim AS app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ gfortran curl \
    && rm -rf /var/lib/apt/lists/*

# Copy Julia runtime and pre-compiled depot from the previous stage
COPY --from=julia-deps /opt/julia-* /opt/julia/
COPY --from=julia-deps /opt/julia_depot /opt/julia_depot
COPY --from=julia-deps /opt/JuTrack.jl /opt/JuTrack.jl
RUN ln -s /opt/julia/bin/julia /usr/local/bin/julia

ENV JULIA_DEPOT_PATH=/opt/julia_depot
ENV JULIA_PROJECT=/opt/JuTrack.jl
# Tell pyJuTrack / juliacall not to try Pkg.update() — everything is pre-baked
ENV JULIA_PKG_OFFLINE=true

WORKDIR /app

# Install Python dependencies first (cached layer)
COPY JuTrack.jl/python_integration /tmp/pyjutrack_src
RUN pip install --no-cache-dir \
        juliacall>=0.9.20 \
        juliapkg>=0.1.10 \
        numpy>=1.24 \
        autogen-agentchat>=0.4 \
        "autogen-ext[openai]>=0.4" \
        streamlit>=1.34 \
        python-dotenv>=1.0 \
        cryptography>=41.0 \
    && pip install --no-cache-dir -e /tmp/pyjutrack_src

# Copy the BRILLIANCE app
COPY . /app

# Warm-up: import pyJuTrack inside the final image to verify the full
# Python→Julia→JuTrack chain works and to cache the .ji files.
RUN python -c "import pyJuTrack as jt; print('pyJuTrack import OK')" 2>&1

EXPOSE 8501

CMD ["streamlit", "run", "app.py", \
     "--server.address=0.0.0.0", \
     "--server.port=8501", \
     "--server.headless=true"]
