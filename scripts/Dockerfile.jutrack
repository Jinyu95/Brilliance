# BRILLIANCE — Docker build for the JuTrack sandbox
#
# Build (standard):
#   docker compose up --build
#
# Build (if registries are unreachable — see docker-compose.override.yml.example):
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose up --build

# ── Stage 1: Julia + JuTrack precompile ──────────────────────────────────────
# python:3.11-slim must exist locally before building.
# If Docker Hub is unreachable, run scripts/pull_base.ps1 (Windows) or
# scripts/pull_base.sh (Linux/macOS) first to pull it from a mirror.
FROM python:3.11-slim AS julia-deps

# patchelf clears executable-stack flags on Julia's shared libraries —
# newer Linux kernels (including WSL2) refuse to load .so files with that flag.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git gcc g++ gfortran make patchelf \
    && rm -rf /var/lib/apt/lists/*

# Julia version and download mirror.
# JULIA_MIRROR — base URL for the tarball directory (no trailing slash).
# Default: official S3.
# Alternative: https://mirrors.bfsu.edu.cn/julia-releases/bin/linux/x64/1.11
ARG JULIA_VERSION=1.11.9
ARG JULIA_ARCH=x86_64
ARG JULIA_MIRROR=https://julialang-s3.julialang.org/bin/linux/x64/1.11

RUN curl -fsSL "${JULIA_MIRROR}/julia-${JULIA_VERSION}-linux-${JULIA_ARCH}.tar.gz" \
    | tar -xz -C /opt && \
    find /opt/julia-${JULIA_VERSION}/lib/julia -name "*.so" | xargs -r patchelf --clear-execstack && \
    ln -s /opt/julia-${JULIA_VERSION}/bin/julia /usr/local/bin/julia

# Copy the bundled JuTrack.jl source (strip .git to avoid Pkg git-path confusion)
COPY JuTrack.jl /opt/JuTrack.jl
RUN rm -rf /opt/JuTrack.jl/.git

# Julia depot lives here and will be copied to the final stage
ENV JULIA_DEPOT_PATH=/opt/julia_depot

# Step 1: instantiate all dependencies and precompile JuTrack.
# Pkg.precompile() compiles JuTrack itself from within its own project —
# no separate Pkg.develop environment needed.
RUN julia --project=/opt/JuTrack.jl -e " \
    import Pkg; \
    Pkg.instantiate(); \
    Pkg.precompile(); \
    println(\"JuTrack precompile complete\"); \
    " 2>&1

# ── Stage 2: Python app ───────────────────────────────────────────────────────
FROM python:3.11-slim AS app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ gfortran curl patchelf \
    && rm -rf /var/lib/apt/lists/*

# Copy Julia runtime and pre-compiled depot from stage 1
COPY --from=julia-deps /opt/julia-* /opt/julia/
COPY --from=julia-deps /opt/julia_depot /opt/julia_depot
COPY --from=julia-deps /opt/JuTrack.jl /opt/JuTrack.jl
RUN ln -s /opt/julia/bin/julia /usr/local/bin/julia

ENV JULIA_DEPOT_PATH=/opt/julia_depot
ENV JULIA_PROJECT=/opt/JuTrack.jl
# No network Julia package resolution at runtime — everything is pre-baked
ENV JULIA_PKG_OFFLINE=true

WORKDIR /app

# Install Python dependencies.
# PIP_INDEX_URL — override for pip mirrors (set via docker-compose.override.yml).
# Default: PyPI.  Alternative: https://pypi.tuna.tsinghua.edu.cn/simple
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY JuTrack.jl/python_integration /tmp/pyjutrack_src
RUN pip install --no-cache-dir -i ${PIP_INDEX_URL} \
        "juliacall>=0.9.20" \
        "juliapkg>=0.1.10" \
        "numpy>=1.24" \
        "autogen-agentchat>=0.4" \
        "autogen-ext[openai]>=0.4" \
        "streamlit>=1.34" \
        "python-dotenv>=1.0" \
    && pip install --no-cache-dir -i ${PIP_INDEX_URL} -e /tmp/pyjutrack_src

# Copy the BRILLIANCE app
COPY . /app

# Verify the full Python → Julia → JuTrack chain works
RUN python -c "import pyJuTrack as jt; print('pyJuTrack import OK')" 2>&1

EXPOSE 8501

CMD ["streamlit", "run", "app.py", \
     "--server.address=0.0.0.0", \
     "--server.port=8501", \
     "--server.headless=true"]
